{
  "name": "fabrica-de-software",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,ts,vue,jsx,tsx,json,css,md}\""
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "axios": "^1.4.0",
    "boxicons": "^2.1.4",
    "pinia": "^2.0.36",
    "vite-plugin-vue-devtools": "^7.0.25",
    "vue": "^3.3.2",
    "vue-multiselect": "^3.4.0",
    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.2.0",
    "@tsconfig/node18": "^18.2.6",
    "@types/jsdom": "^21.1.1",
    "@types/node": "^18.16.8",
    "@typescript-eslint/eslint-plugin": "^5.60.1",
    "@typescript-eslint/parser": "^5.60.1",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.3.2",
    "@vue/tsconfig": "^0.4.0",
    "cypress": "^14.3.2",
    "eslint": "^8.45.0",
    "eslint-plugin-cypress": "^2.13.3",
    "eslint-plugin-vue": "^9.15.1",
    "prettier": "^2.8.8",
    "typescript": "~5.0.4",
    "vite": "^6.3.3",
    "vite-plugin-vue-devtools": "^7.0.25",
    "vitest": "^3.1.2",
    "vue-tsc": "^1.6.4"
  }
}
